GMAIL_ADDRESS=serversignal0@gmail.com
GMAIL_APP_PASSWORD=your-app-password
ADMIN_EMAIL=your-personal@email.com

# Container path — matches the volume mount in the systemd service and podman run command.
# For local dev outside the container, change to: DB_PATH=./born-to-be-wild.sqlite
DB_PATH=/data/born-to-be-wild.sqlite

LOG_LEVEL=INFO

# Textbelt SMS (optional — leave blank to disable SMS)
TEXTBELT_API_KEY=your-textbelt-api-key

# Pirate Weather (optional — supplemental precip source; leave blank to skip)
# Free tier: 10k calls/month at https://pirateweather.net
PIRATE_WEATHER_API_KEY=your-pirate-weather-key
